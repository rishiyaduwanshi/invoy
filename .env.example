# Copy this file to .env and fill in your values

# Tawk.to Live Chat
# Get from: https://dashboard.tawk.to > Administration > Chat Widget
# Example: PUBLIC_TAWK_PROPERTY_ID=679abc123456789abc123456
PUBLIC_TAWK_PROPERTY_ID=your_property_id_here

# Widget/Inbox ID (usually "default" or "1hbcdef0a")
PUBLIC_TAWK_WIDGET_ID=default
