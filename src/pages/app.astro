---
import "../global.css"
import InvoiceApp from '../components/InvoiceApp.jsx';
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Outfit:wght@400;500;700;800;900&display=swap" rel="stylesheet">
		<title>Invoice Generator — Invoy</title>
		<meta name="description" content="Create professional, GST-compliant invoices instantly. Invoy is free, private, and works 100% in your browser." />
	</head>
	<body class="bg-[#050505] min-h-screen text-white font-sans antialiased overflow-x-hidden">
		
		{/* Ambient Background Glows */}
		<div class="fixed top-[-10%] left-[-10%] w-[40%] h-[40%] rounded-full bg-blue-600/10 blur-[120px] pointer-events-none z-0"></div>
		<div class="fixed bottom-[-10%] right-[-10%] w-[40%] h-[40%] rounded-full bg-purple-600/10 blur-[120px] pointer-events-none z-0"></div>

		<main class="relative z-10">
			<InvoiceApp client:load />
		</main>

	</body>
</html>
