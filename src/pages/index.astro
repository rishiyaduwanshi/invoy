---
import "../global.css"
import InvoiceApp from '../components/InvoiceApp.jsx';
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width" />
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Outfit:wght@400;500;700&display=swap" rel="stylesheet">
		<title>Invoy - Free Online Invoice Generator for India</title>
		<meta name="description" content="Invoy is a modern, free GST-compliant invoice generator for Indian freelancers and businesses. Export beautiful PDFs instantly." />
	</head>
	<body class="bg-[#050505] min-h-screen text-white font-sans antialiased relative overflow-x-hidden">
		{/* Ambient Background Glows */}
		<div class="fixed top-[-10%] left-[-10%] w-[40%] h-[40%] rounded-full bg-blue-600/10 blur-[120px] pointer-events-none"></div>
		<div class="fixed bottom-[-10%] right-[-10%] w-[40%] h-[40%] rounded-full bg-indigo-600/10 blur-[120px] pointer-events-none"></div>

		
		<main>
			{/* The React Application */}
			<InvoiceApp client:load />
		</main>

		{/* Premium Assignment Requirements Footer */}
		<footer class="relative z-10 border-t border-white/10 bg-black/40 backdrop-blur-3xl py-16 px-6 mt-16 text-center">
			<div class="max-w-5xl mx-auto grid grid-cols-1 md:grid-cols-3 gap-12 items-center text-left">
				
				{/* Left: About */}
				<div class="flex flex-col gap-3 items-center md:items-start text-center md:text-left">
					<h3 class="text-white font-['Outfit'] font-bold text-xl tracking-tight">Invoy</h3>
					<p class="text-neutral-400 text-sm max-w-xs leading-relaxed">
						The modern, completely free GST invoice generator for Indian businesses. No subscriptions, just fast and beautiful PDFs.
					</p>
				</div>

				{/* Middle: Mandatory Button */}
				<div class="flex justify-center">
					<a 
						href="https://invoy.in" 
						target="_blank" 
						rel="noopener noreferrer"
						class="inline-flex items-center justify-center bg-gradient-to-r from-indigo-600 to-purple-600 text-white font-bold px-8 py-3.5 rounded-full hover:scale-[1.03] hover:shadow-[0_0_30px_rgba(79,70,229,0.5)] transition-all duration-300 ring-1 ring-white/20"
					>
						Visit invoy.in
					</a>
				</div>

				{/* Right: Creator Details */}
				<div class="flex flex-col items-center md:items-end text-center md:text-right gap-1">
					<h3 class="text-xs uppercase tracking-widest text-indigo-400 font-semibold mb-2">Support & Feedback</h3>
					<p class="text-white font-['Outfit'] font-bold text-2xl tracking-tight">Invoy Team</p>
					<a href="mailto:hello@invoy.in" class="text-neutral-400 hover:text-white transition-colors text-sm flex items-center gap-2 mt-1">
						<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-indigo-400"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
						hello@invoy.in
					</a>
				</div>

			</div>
		</footer>
	</body>
</html>
