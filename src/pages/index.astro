---
import "../global.css"
---

<html lang="en" class="scroll-smooth">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width" />
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Outfit:wght@400;500;700;800;900&display=swap" rel="stylesheet">
		<title>Invoy - Free Online Invoice Generator for India</title>
		<meta name="description" content="Create professional, GST-compliant invoices in seconds. Invoy is the fastest, completely free invoice generator for Indian freelancers and MSMEs." />
		
		{/* JSON-LD for SoftwareApplication and AEO */}
		<script type="application/ld+json">
		{
		  "@context": "https://schema.org",
		  "@type": "SoftwareApplication",
		  "name": "Invoy",
		  "operatingSystem": "Web",
		  "applicationCategory": "BusinessApplication",
		  "offers": {
			"@type": "Offer",
			"price": "0",
			"priceCurrency": "INR"
		  },
		  "description": "A completely free, 100% client-side GST invoice generator tailored for Indian businesses and freelancers."
		}
		</script>
		<script type="application/ld+json">
		{
		  "@context": "https://schema.org",
		  "@type": "FAQPage",
		  "mainEntity": [{
			"@type": "Question",
			"name": "Is Invoy really free?",
			"acceptedAnswer": {
			  "@type": "Answer",
			  "text": "Yes, Invoy is completely free to use with no hidden fees, subscriptions, or watermarks."
			}
		  }, {
			"@type": "Question",
			"name": "Does it save my data on servers?",
			"acceptedAnswer": {
			  "@type": "Answer",
			  "text": "No, Invoy runs 100% locally in your browser. None of your client data or invoices are saved on our servers, guaranteeing complete privacy."
			}
		  }]
		}
		</script>
	</head>
	<body class="bg-[#050505] min-h-screen text-white font-sans antialiased relative overflow-x-hidden selection:bg-indigo-500/30 selection:text-indigo-200">
		
		{/* Ambient Background Glows */}
		<div class="fixed top-[-20%] left-[-10%] w-[50%] h-[50%] rounded-full bg-blue-600/10 blur-[150px] pointer-events-none z-0"></div>
		<div class="fixed bottom-[-10%] right-[-10%] w-[40%] h-[40%] rounded-full bg-purple-600/10 blur-[150px] pointer-events-none z-0"></div>

		{/* Header */}
		<header class="fixed top-0 w-full z-50 bg-black/50 backdrop-blur-xl border-b border-white/5 transition-all duration-300">
			<div class="max-w-7xl mx-auto px-6 h-20 flex items-center justify-between">
				<div class="flex items-center gap-2">
					<div class="w-8 h-8 rounded-lg bg-gradient-to-br from-indigo-500 to-purple-600 flex items-center justify-center font-bold text-lg shadow-[0_0_15px_rgba(79,70,229,0.5)]">
						I
					</div>
					<span class="text-xl font-['Outfit'] font-black tracking-widest text-white">INVOY</span>
				</div>
				<nav class="hidden md:flex items-center gap-8 text-sm font-medium text-neutral-300">
					<a href="#features" class="hover:text-white transition-colors">Features</a>
					<a href="#how-it-works" class="hover:text-white transition-colors">How it Works</a>
					<a href="#faq" class="hover:text-white transition-colors">FAQ</a>
				</nav>
				<a href="/app" class="bg-white text-black px-6 py-2.5 rounded-full font-bold text-sm hover:scale-105 hover:bg-neutral-200 transition-all shadow-[0_0_20px_rgba(255,255,255,0.2)]">
					Open App
				</a>
			</div>
		</header>

		<main class="relative z-10 pt-32">
			
			{/* Hero Section */}
			<section class="min-h-[85vh] flex flex-col items-center justify-center text-center px-4 relative">
				<div class="inline-block mb-6 px-4 py-1.5 rounded-full border border-indigo-500/30 bg-indigo-500/10 text-indigo-300 text-sm font-semibold tracking-wide backdrop-blur-md animate-fade-in">
					✨ Launching Invoy 1.0
				</div>
				<h1 class="text-5xl md:text-7xl font-black font-['Outfit'] tracking-tight max-w-4xl leading-tight mb-8 drop-shadow-2xl opacity-0 animate-fade-in-up" style="animation-delay: 100ms; animation-fill-mode: forwards;">
					Create Professional <span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-400 via-indigo-400 to-purple-400">GST Invoices</span> in Seconds
				</h1>
				<p class="text-lg md:text-xl text-neutral-400 max-w-2xl mb-12 leading-relaxed opacity-0 animate-fade-in-up" style="animation-delay: 200ms; animation-fill-mode: forwards;">
					The fastest, completely free invoice generator tailored for Indian MSMEs and freelancers. No subscriptions, no watermarks, 100% privacy.
				</p>
				<div class="flex flex-col sm:flex-row gap-4 opacity-0 animate-fade-in-up" style="animation-delay: 300ms; animation-fill-mode: forwards;">
					<a href="/app" class="px-8 py-4 bg-gradient-to-r from-indigo-600 to-purple-600 rounded-full font-bold text-lg hover:scale-105 hover:shadow-[0_0_30px_rgba(79,70,229,0.5)] transition-all ring-1 ring-white/20">
						Create Free Invoice
					</a>
					<a href="#features" class="px-8 py-4 bg-white/5 backdrop-blur-md border border-white/10 rounded-full font-bold text-lg hover:bg-white/10 transition-all text-neutral-300 hover:text-white">
						Explore Features
					</a>
				</div>

				{/* Floating UI Mockup Representation */}
				<div class="mt-20 relative w-full max-w-5xl mx-auto opacity-0 animate-fade-in-up" style="animation-delay: 500ms; animation-fill-mode: forwards;">
					<div class="absolute inset-0 bg-gradient-to-t from-[#050505] via-transparent to-transparent z-10 h-full"></div>
					<div class="bg-white/5 border border-white/10 backdrop-blur-3xl rounded-t-3xl p-4 shadow-2xl relative overflow-hidden">
						<div class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-blue-500 via-indigo-500 to-purple-500"></div>
						<div class="flex gap-2 mb-6 ml-2 mt-2">
							<div class="w-3 h-3 rounded-full bg-red-500/50"></div>
							<div class="w-3 h-3 rounded-full bg-yellow-500/50"></div>
							<div class="w-3 h-3 rounded-full bg-green-500/50"></div>
						</div>
						<div class="grid grid-cols-1 md:grid-cols-2 gap-8 px-4 pb-20">
							<div class="space-y-4">
								<div class="h-10 w-full bg-white/5 rounded-xl border border-white/5"></div>
								<div class="h-24 w-full bg-white/5 rounded-xl border border-white/5"></div>
								<div class="h-10 w-2/3 bg-white/5 rounded-xl border border-white/5"></div>
							</div>
							<div class="h-64 w-full bg-white/10 rounded-xl border border-white/10 shadow-[0_0_30px_rgba(79,70,229,0.1)]"></div>
						</div>
					</div>
				</div>
			</section>

			{/* Features Section */}
			<section id="features" class="py-24 px-6 max-w-7xl mx-auto border-t border-white/5 mt-[-100px] relative z-20">
				<div class="text-center mb-16">
					<h2 class="text-3xl md:text-5xl font-black font-['Outfit'] mb-4">Why choose Invoy?</h2>
					<p class="text-neutral-400 max-w-2xl mx-auto">Everything you need to bill clients professionally, without the complexity of bloated accounting software.</p>
				</div>
				<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
					{/* Feature 1 */}
					<div class="p-8 rounded-2xl bg-white/5 border border-white/10 hover:bg-white/10 transition-colors group">
						<div class="w-12 h-12 bg-indigo-500/20 text-indigo-400 rounded-xl flex items-center justify-center mb-6 group-hover:scale-110 transition-transform">
							<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line><polyline points="10 9 9 9 8 9"></polyline></svg>
						</div>
						<h3 class="text-xl font-bold mb-3">MSME & GST Compliant</h3>
						<p class="text-neutral-400 text-sm leading-relaxed">Built specifically for Indian standards. Supports CGST, SGST, IGST calculations and Udyam Registration numbers out of the box.</p>
					</div>
					{/* Feature 2 */}
					<div class="p-8 rounded-2xl bg-white/5 border border-white/10 hover:bg-white/10 transition-colors group">
						<div class="w-12 h-12 bg-purple-500/20 text-purple-400 rounded-xl flex items-center justify-center mb-6 group-hover:scale-110 transition-transform">
							<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path></svg>
						</div>
						<h3 class="text-xl font-bold mb-3">100% Privacy</h3>
						<p class="text-neutral-400 text-sm leading-relaxed">Your data never leaves your browser. Invoices are generated locally so your financial details and client data remain completely private.</p>
					</div>
					{/* Feature 3 */}
					<div class="p-8 rounded-2xl bg-white/5 border border-white/10 hover:bg-white/10 transition-colors group">
						<div class="w-12 h-12 bg-blue-500/20 text-blue-400 rounded-xl flex items-center justify-center mb-6 group-hover:scale-110 transition-transform">
							<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 2 7 12 12 22 7 12 2"></polygon><polyline points="2 17 12 22 22 17"></polyline><polyline points="2 12 12 17 22 12"></polyline></svg>
						</div>
						<h3 class="text-xl font-bold mb-3">Multiple Templates</h3>
						<p class="text-neutral-400 text-sm leading-relaxed">Choose between a sleek Modern layout or a formal Classic (MSME) template with proper signature and declaration sections.</p>
					</div>
				</div>
			</section>

			{/* How it Works */}
			<section id="how-it-works" class="py-24 px-6 bg-white/5 border-y border-white/5">
				<div class="max-w-4xl mx-auto text-center">
					<h2 class="text-3xl md:text-5xl font-black font-['Outfit'] mb-16">3 Simple Steps</h2>
					<div class="grid grid-cols-1 md:grid-cols-3 gap-8">
						<div>
							<div class="text-6xl font-black text-indigo-500/20 mb-4 font-['Outfit']">1</div>
							<h3 class="text-xl font-bold mb-2">Fill Details</h3>
							<p class="text-neutral-400 text-sm">Enter your business info and client details. Upload your logo and signature.</p>
						</div>
						<div>
							<div class="text-6xl font-black text-purple-500/20 mb-4 font-['Outfit']">2</div>
							<h3 class="text-xl font-bold mb-2">Add Items</h3>
							<p class="text-neutral-400 text-sm">List your services, rates, and quantities. GST is calculated automatically.</p>
						</div>
						<div>
							<div class="text-6xl font-black text-blue-500/20 mb-4 font-['Outfit']">3</div>
							<h3 class="text-xl font-bold mb-2">Export PDF</h3>
							<p class="text-neutral-400 text-sm">Click download to get a pixel-perfect PDF ready to send to your client.</p>
						</div>
					</div>
				</div>
			</section>

			{/* FAQ Section */}
			<section id="faq" class="py-24 px-6 max-w-3xl mx-auto">
				<div class="text-center mb-16">
					<h2 class="text-3xl md:text-5xl font-black font-['Outfit'] mb-4">Frequently Asked Questions</h2>
				</div>
				<div class="space-y-6">
					<div class="p-6 rounded-2xl bg-white/5 border border-white/10">
						<h3 class="text-lg font-bold mb-2">Is Invoy really free?</h3>
						<p class="text-neutral-400 text-sm">Yes, completely free. There are no paywalls, subscriptions, or watermarks on your PDFs.</p>
					</div>
					<div class="p-6 rounded-2xl bg-white/5 border border-white/10">
						<h3 class="text-lg font-bold mb-2">How is my data stored?</h3>
						<p class="text-neutral-400 text-sm">Invoy operates entirely in your web browser using local state. We do not have servers that store your invoices or client data.</p>
					</div>
					<div class="p-6 rounded-2xl bg-white/5 border border-white/10">
						<h3 class="text-lg font-bold mb-2">Can I use it without GST?</h3>
						<p class="text-neutral-400 text-sm">Absolutely. There is a simple toggle in the form to turn off GST if you are a freelancer below the GST threshold.</p>
					</div>
				</div>
			</section>

		</main>

		{/* Footer */}
		<footer class="border-t border-white/10 bg-black/40 backdrop-blur-3xl py-12 px-6 text-center">
			<div class="max-w-7xl mx-auto flex flex-col md:flex-row items-center justify-between gap-6">
				<div class="flex items-center gap-2">
					<div class="w-6 h-6 rounded bg-gradient-to-br from-indigo-500 to-purple-600 flex items-center justify-center font-bold text-xs">I</div>
					<span class="font-['Outfit'] font-black tracking-widest text-white">INVOY</span>
				</div>
				<p class="text-neutral-500 text-sm">© {new Date().getFullYear()} Invoy. Built for Indian Businesses.</p>
				<div class="flex gap-4">
					<a href="https://github.com/rishiyaduwanshi/invoy" class="text-neutral-500 hover:text-white transition-colors">GitHub</a>
					<a href="mailto:hello@invoy.in" class="text-neutral-500 hover:text-white transition-colors">Support</a>
				</div>
			</div>
		</footer>

		{/* Inline styles for basic animations */}
		<style is:inline>
			@keyframes fadeInUp {
				from { opacity: 0; transform: translateY(20px); }
				to { opacity: 1; transform: translateY(0); }
			}
			@keyframes fadeIn {
				from { opacity: 0; }
				to { opacity: 1; }
			}
			.animate-fade-in-up {
				opacity: 0;
				animation: fadeInUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
			}
			.animate-fade-in {
				opacity: 0;
				animation: fadeIn 1s ease-out forwards;
			}
		</style>
	</body>
</html>
